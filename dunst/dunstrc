# See dunst(5) for all configuration options

[global]
    origin = top-right
    offset = 10x50
    font = NotoSans NF 14
    notification_limit = 5
    frame_width = 2
    frame_color = "#928374"

    width = (0, 450)
    height = 200
    padding = 16
    horizontal_padding = 20
    vertical_alignment = center
    show_age_threshold = 60
    stack_duplicates = true
    show_indicators = yes
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    ellipsize = middle
    ignore_newline = no
    corner_radius = 5
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#282828"
    foreground = "#928374"
    timeout = 5
    frame_color = "#458588"

[urgency_normal]
    background = "#282828"
    foreground = "#ebdbb2"
    timeout = 5
    frame_color = "#458588"

[urgency_critical]
    background = "#cc241d"
    foreground = "#ebdbb2"
    frame_color = "#fabd2f"
    timeout = 0 


[experimental]
    per_monitor_dpi = false


# vim: ft=cfg
