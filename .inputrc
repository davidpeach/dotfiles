set show-all-if-ambiguous on
set colored-stats on
set completion-display-width 0
set completion-ignore-case on
set colored-completion-prefix on
set expand-tilde on

set editing-mode vi
set show-mode-in-prompt on
set vi-ins-mode-string "\1\e[\033\e[92;70m\2󰴓  \1\e[\033\e[0m\2"
set vi-cmd-mode-string "\1\e[\033\e[31;1m\2  \1\e[\033\e[0m\2"
set keyseq-timeout 10
Control-p: "pwd \r"
Control-h: "cd\rclear\r"
Control-o: "cd ..\nclear\n"
Control-u: backward-kill-word
